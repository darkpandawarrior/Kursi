<?xml version="1.0" encoding="utf-8"?>
<!-- Gms-flavor-only manifest additions: Firebase Cloud Messaging init + the FCM service.
     Not present in the noGms (F-Droid) flavor — see publish-fdroid.yml. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application>

        <!-- Defer Firebase init until google-services.json + FirebaseApp.initializeApp() are wired. -->
        <meta-data
            android:name="firebase_messaging_auto_init_enabled"
            android:value="false" />
        <meta-data
            android:name="firebase_auto_data_collection_enabled"
            android:value="false" />
        <provider
            android:name="com.google.firebase.provider.FirebaseInitProvider"
            android:authorities="${applicationId}.firebaseinitprovider"
            android:exported="false"
            tools:node="remove" />

        <service
            android:name=".KursiFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
