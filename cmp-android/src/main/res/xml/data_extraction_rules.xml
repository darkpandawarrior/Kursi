<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ data extraction rules.
    Career stats and game settings are user data — include in cloud backup
    and device-to-device transfer. Exclude session state.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="kursi_session.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="kursi_session.xml" />
    </device-transfer>
</data-extraction-rules>
