.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar
local.properties
.kotlin/
*.hprof
.DS_Store
.idea/

# Build outputs (generated artifacts, not source)
outputs/

# Render byproduct — the screenshot harness writes cropped region variants to a
# crop/ subdir; only the top-level PNGs are tracked baselines. Keep crop/ out of
# the committed gallery (CI copies build/shots/. into docs/screenshots/).
docs/screenshots/crop/

# Signing secrets — NEVER commit these
keystore.properties
*.keystore
*.jks
secrets/

# Environment / CI
.env
google-services.json
GoogleService-Info.plist
RALPH_PLAN.md
RALPH_PROGRESS.md
*.md.bak
