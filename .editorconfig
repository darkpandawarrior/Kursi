root = true

# Generated KSP/Gradle code — never lint
[**/build/**/*.kt]
ktlint = disabled

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.kt]
max_line_length = 160
# Composable functions use PascalCase — disable the Kotlin function-naming rule globally.
ktlint_standard_function-naming = disabled
# Matches detekt's WildcardImport.active=false: Compose + Kursi design-system generate many
# wildcard imports via IDE, and engine.* call sites intentionally pull in many symbols at once.
ktlint_standard_no-wildcard-imports = disabled

[*.kts]
max_line_length = 160

[*.{yml,yaml}]
indent_size = 2

[*.{xml,svg}]
indent_size = 4

[*.toml]
indent_size = 4
